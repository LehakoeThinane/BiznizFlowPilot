# Database
DATABASE_URL=postgresql://postgres:020890@localhost:5433/biznizflow_test
SQLALCHEMY_ECHO=True

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# FastAPI
DEBUG=True
APP_NAME=BiznizFlowPilot
LOG_LEVEL=INFO

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True
SMTP_USE_SSL=False
SMTP_FROM_EMAIL=noreply@biznizflowpilot.com
SMTP_FROM_NAME=BiznizFlowPilot
SMTP_TIMEOUT_SECONDS=10

# Celery Beat intervals (seconds)
STALE_CLAIM_CHECK_INTERVAL_SECONDS=60
ACTION_RETRY_CHECK_INTERVAL_SECONDS=60
STALE_RUN_CHECK_INTERVAL_SECONDS=300

# Environment
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
